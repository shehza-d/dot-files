{
  "editor.fontSize": 19,
  "editor.cursorStyle": "block",
  "editor.insertSpaces": false,
  "update.enableWindowsBackgroundUpdates": false,
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  "[css]": {
    "editor.defaultFormatter": "vscode.css-language-features"
  },
  "files.autoSaveDelay": 0,
  "workbench.iconTheme": "material-icon-theme",
  // "editor.fontFamily": "'cascadia code',Consolas, 'Courier New', monospace",
  "editor.fontFamily": "Fira Code Medium, monospace",
  "editor.fontLigatures": true,
  "terminal.integrated.fontFamily": "monospace",
  "window.title": "${dirty}${activeEditorShort}${separator}${rootName}${separator} Shehzad❤",
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.inlineSuggest.enabled": true,
  "bracket-pair-colorizer-2.depreciation-notice": false,
  "github.copilot.enable": {
    "*": true,
    "yaml": false,
    "plaintext": false,
    "markdown": true,
    "javascript": false,
    "html": true
  },
  "editor.suggest.showStatusBar": true,
  "material-icon-theme.showUpdateMessage": true,
  "explorer.confirmDelete": false,
  "tabnine.experimentalAutoImports": true,
  "liveServer.settings.donotVerifyTags": true,
  "liveServer.settings.donotShowInfoMsg": true,
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "javascript.updateImportsOnFileMove.enabled": "always",
  "editor.fontWeight": "normal",
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "workbench.startupEditor": "none",
  "terminal.integrated.defaultProfile.windows": "Command Prompt",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.confirmOnExit": "hasChildProcesses",
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "git.autofetch": true,
  "git.enableSmartCommit": true,
  "git.confirmSync": false,
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "files.associations": {
    "\"*.css\"": "\"tailwindcss\"",
    "*.css": "tailwindcss"
  },
  "editor.quickSuggestions": {
    "strings": "on"
  },
  "tailwindCSS.includeLanguages": {
    "plaintext": "html"
  },
  "extensions.ignoreRecommendations": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "cSpell.userWords": [
    "SAYLANI",
    "Shehzad",
    "tailwindcss"
  ],
  "material-icon-theme.activeIconPack": "react",
  "workbench.colorCustomizations": {},
  "cSpell.diagnosticLevel": "Warning",
  "cSpell.minWordLength": 3,
  "cSpell.logLevel": "Information",
  "react-native-tools.showUserTips": false,
  "workbench.colorTheme": "Synth Wave '84 Luis Reyes' Remix",
  "totalTypeScript.hideAllTips": false,
  "totalTypeScript.hideBasicTips": false,
  "editor.formatOnSave": true,
  "turboConsoleLog.quote": "`"
  // "editor.fontLigatures": false
}