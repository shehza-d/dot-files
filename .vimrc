" Line numbers
set number relativenumber

" Better indentation
set tabstop=4
set shiftwidth=4
set expandtab
set smartindent

" Search improvements
set ignorecase
set smartcase
set incsearch
set hlsearch

" Show cursor position
set ruler

" Enable mouse (optional but useful)
set mouse=a

" Keep some lines visible when scrolling
set scrolloff=8

" Faster updates
set updatetime=300

